# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Xcode
*.xcodeproj
*.xcworkspace
xcuserdata/
DerivedData/
*.xcscmblueprint
*.xccheckout

# Swift Package Manager
.build/
.swiftpm/

# Environment / secrets
.env
.env.local
.env.*.local

# IDE
*.swp
*~
.idea/
.vscode/

# Node.js (tado-mcp)
node_modules/
npm-debug.log*

# Claude Code (user-local settings)
.claude/

# Rust core build artifacts
tado-core/target/
tado-core/include/tado_core.h

# Tado per-repo runtime state (Eternal/Dispatch runs on this repo).
# These are generated on each run and are per-developer; they're not
# part of the app's source.
.tado/eternal/
.tado/dispatch/
.tado/memory/notes/

# AtomicStore flock byproducts under .tado/. Created next to every
# tracked file we touch; always 0 bytes; never meaningful diff.
.tado/*.lock
.tado/.*.lock
